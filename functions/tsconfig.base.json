{
  "compilerOptions": {
    "module": "NodeNext",
    "esModuleInterop": true,
    "moduleResolution": "nodenext",
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "outDir": "lib",
    "rootDir": "src",
    "sourceMap": true,
    "strict": true,
    "target": "es2017",
    "experimentalDecorators": true,
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@app/backend-framework": [
        "packages/lib/backend-framework/src"
      ],
      "@app/health-service": [
        "packages/services/health/src"
      ],
      "@app/api-function": [
        "packages/functions/api/src"
      ]
    }
  }
}
